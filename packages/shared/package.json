{
  "name": "@autoops/shared",
  "version": "0.0.1",
  "private": true,
  "description": "Shared types, utilities, and constants for AutoOps",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./types": {
      "types": "./src/types/index.ts",
      "import": "./dist/types/index.js",
      "require": "./dist/types/index.cjs"
    },
    "./utils": {
      "types": "./src/utils/index.ts",
      "import": "./dist/utils/index.js",
      "require": "./dist/utils/index.cjs"
    },
    "./constants": {
      "types": "./src/constants/index.ts",
      "import": "./dist/constants/index.js",
      "require": "./dist/constants/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@autoops/config": "workspace:*",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3"
  }
}
