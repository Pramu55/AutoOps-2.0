# =============================================================================
# AutoOps Hosted Demo Environment Template
# =============================================================================

# ----------------------------
# Runtime
# ----------------------------
NODE_ENV=production
LOG_LEVEL=info
STRICT_ENV_VALIDATION=false

# ----------------------------
# API & Web Networking
# ----------------------------
API_PORT=4000
API_HOST=0.0.0.0
WEB_PORT=3000

# Set these to your public Railway domain:
API_PUBLIC_URL=https://<your-public-domain>
NEXT_PUBLIC_API_URL=https://<your-public-domain>
CORS_ORIGINS=https://<your-public-domain>

# Internal service URL (Railway private network)
API_INTERNAL_URL=http://api:4000

# ----------------------------
# Database & Redis (Managed)
# ----------------------------
# Railway will inject these automatically if you use their managed services:
DATABASE_URL=postgresql://autoops:change-me-local-only@postgres:5432/autoops?schema=public
REDIS_URL=redis://redis:6379

# ----------------------------
# Auth / JWT
# ----------------------------
# Generate two random 64-character strings for these:
JWT_SECRET=replace-with-strong-random-access-secret-32-plus-chars
JWT_REFRESH_SECRET=replace-with-different-strong-random-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ----------------------------
# Demo Login Details
# ----------------------------
# Change this to something appropriate for the public demo:
SEED_PASSWORD=DemoSafePass123!
SEED_EMAIL=pramod.local@autoops.dev
SEED_APPROVER_EMAIL=approver.local@autoops.dev

# ----------------------------
# Provider Isolation Rules
# ----------------------------
# Enable provider inventory ONLY for the demo organization
PROVIDER_INVENTORY_ALLOWED_ORGANIZATION_SLUGS=autoops-demo
PROVIDER_INVENTORY_ALLOWED_ORGANIZATION_IDS=

# =============================================================================
# DISABLED PROVIDERS (Hosted Demo Safety)
# =============================================================================

# Local execution
INFRA_AUTOMATION_ENABLED=false
DOCKER_SOCKET_PATH=
DOCKER_HOST=

# Kubernetes
KUBECONFIG=
KUBECONFIG_HOST_PATH=
KUBERNETES_API_SERVER_OVERRIDE=

# Jenkins
JENKINS_URL=
JENKINS_API_TOKEN=

# AWS
AWS_INTEGRATION_ENABLED=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# GitHub
GITHUB_ACTIONS_ENABLED=false
GITHUB_ACTIONS_TOKEN=

# Cloud
AZURE_INTEGRATION_ENABLED=false
GCP_INTEGRATION_ENABLED=false
