# =============================================================================
# AutoOps environment template
# Copy to `.env` for local development or company-pilot deployment.
# Never commit `.env`. Rotate every secret before production use.
# =============================================================================

# ----------------------------
# Runtime
# ----------------------------
NODE_ENV=development
LOG_LEVEL=debug
# Enable in production/company-pilot deployments to reject placeholder JWT secrets.
# Keep false for the default local Docker Compose demo unless you rotate local secrets first.
STRICT_ENV_VALIDATION=false

# ----------------------------
# API
# ----------------------------
API_PORT=4000
API_HOST=0.0.0.0
API_PUBLIC_URL=http://localhost:4000

# ----------------------------
# Web
# ----------------------------
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000
NEXT_PUBLIC_APP_NAME=AutoOps
API_INTERNAL_URL=http://api:4000

# ----------------------------
# PostgreSQL
# ----------------------------
POSTGRES_USER=autoops
POSTGRES_PASSWORD=change-me-local-only
POSTGRES_DB=autoops
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://autoops:change-me-local-only@postgres:5432/autoops?schema=public

# ----------------------------
# Redis
# ----------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379

# ----------------------------
# Auth / JWT
# ----------------------------
# Production must use two different strong random secrets, 32+ characters each.
# Placeholder values are rejected when NODE_ENV=production and STRICT_ENV_VALIDATION=true.
JWT_SECRET=replace-with-strong-random-access-secret-32-plus-chars
JWT_REFRESH_SECRET=replace-with-different-strong-random-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ----------------------------
# Password hashing
# ----------------------------
ARGON2_MEMORY_COST=19456
ARGON2_TIME_COST=2
ARGON2_PARALLELISM=1

# ----------------------------
# CORS and rate limiting
# ----------------------------
CORS_ORIGINS=http://localhost:3000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# ----------------------------
# Jenkins optional connector
# ----------------------------
# Leave blank to show NOT_CONFIGURED without crashing the platform.
# Use a Jenkins API token, not a Jenkins password.
JENKINS_URL=http://host.docker.internal:8080
JENKINS_USERNAME=
JENKINS_API_TOKEN=
JENKINS_ALLOWED_JOBS=autoops-smoke-build
JENKINS_REQUEST_TIMEOUT_MS=10000
JENKINS_TRIGGER_POLL_TIMEOUT_MS=120000
JENKINS_TRIGGER_POLL_INTERVAL_MS=2000

# ----------------------------
# Docker optional connector
# ----------------------------
# Local controlled-operation runtime can mount the Docker socket.
# Avoid Docker socket access in production unless the risk is explicitly accepted.
DOCKER_SOCKET_PATH=/var/run/docker.sock
DOCKER_HOST=

# ----------------------------
# Kubernetes optional connector
# ----------------------------
# Mount kubeconfig read-only. Never commit kubeconfig or cluster credentials.
KUBECONFIG=/app/.kube/config
KUBECONFIG_HOST_PATH=
KUBERNETES_API_SERVER_OVERRIDE=
KUBERNETES_TLS_SERVER_NAME_OVERRIDE=127.0.0.1
KUBERNETES_ALLOWED_NAMESPACES=
KUBERNETES_MAX_REPLICAS=10

# ----------------------------
# Infrastructure automation optional connector
# ----------------------------
# Local-first Terraform/OpenTofu and Ansible automation.
# Only allowlisted workspaces/playbooks under these roots are executable.
# No cloud credentials are required for the included local smoke examples.
INFRA_AUTOMATION_ENABLED=true
INFRA_TERRAFORM_ROOT=/app/infra/terraform
INFRA_ANSIBLE_ROOT=/app/infra/ansible
INFRA_OPERATION_TIMEOUT_SECONDS=180
INFRA_EXPORT_OUTPUT_LIMIT=8000

# ----------------------------
# Worker
# ----------------------------
WORKER_PORT=4001
WORKER_HOST=0.0.0.0
DEPLOYMENTS_CONCURRENCY=5
BUILDS_CONCURRENCY=3
AI_CONCURRENCY=2

# ----------------------------
# Observability
# ----------------------------
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-local-only

# ----------------------------
# Local demo notes
# ----------------------------
# The database seed creates local demo users for approval testing only.
# Do not use demo users or demo passwords in real company deployments.
SEED_EMAIL=pramod.local@autoops.dev
SEED_APPROVER_EMAIL=approver.local@autoops.dev
SEED_PASSWORD=StrongPass123

# ----------------------------
# Production notes
# ----------------------------
# - Set NODE_ENV=production.
# - Use a secrets manager where possible.
# - Use strong database and Redis credentials.
# - Restrict CORS_ORIGINS to real web origins.
# - Leave optional connectors blank unless intentionally configured.
# - Missing optional connectors should report NOT_CONFIGURED, not crash AutoOps.
