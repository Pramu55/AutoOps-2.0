# =============================================================================
# AutoOps 3.0 — Environment template
# Copy to `.env` for local dev. Real values must NEVER be committed.
# =============================================================================

# -- Runtime ---------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=debug

# -- API server ------------------------------------------------------------
API_PORT=4000
API_HOST=0.0.0.0
API_PUBLIC_URL=http://localhost:4000
CORS_ORIGINS=http://localhost:3000

# -- Web (Next.js) ---------------------------------------------------------
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000
NEXT_PUBLIC_APP_NAME=AutoOps

# -- Postgres --------------------------------------------------------------
POSTGRES_USER=autoops
POSTGRES_PASSWORD=autoops_dev_password
POSTGRES_DB=autoops
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://autoops:autoops_dev_password@postgres:5432/autoops?schema=public

# -- Redis -----------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379

# -- Auth ------------------------------------------------------------------
JWT_SECRET=please-change-me-in-production-min-32-chars
JWT_REFRESH_SECRET=please-also-change-this-in-production-32c
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
ARGON2_MEMORY_COST=19456
ARGON2_TIME_COST=2
ARGON2_PARALLELISM=1

# -- Rate limiting ---------------------------------------------------------
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# -- AI providers (Phase 4) ------------------------------------------------
AI_DEFAULT_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1

# -- Observability ---------------------------------------------------------
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# -- Nginx -----------------------------------------------------------------
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
