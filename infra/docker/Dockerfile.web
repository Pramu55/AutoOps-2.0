# ─────────────────────────────────────────────────────────────────────────────
# Stage 1: Builder
# ─────────────────────────────────────────────────────────────────────────────
FROM node:20-alpine AS builder

RUN apk add --no-cache openssl

WORKDIR /repo

ENV PATH="/repo/node_modules/.bin:$PATH"
ENV NEXT_TELEMETRY_DISABLED=1

ARG NEXT_PUBLIC_API_URL=http://localhost:4000
ARG API_INTERNAL_URL=http://api:4000

ENV NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL}
ENV API_INTERNAL_URL=${API_INTERNAL_URL}

RUN corepack enable && corepack prepare pnpm@9.12.0 --activate

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./

COPY packages/config-typescript/package.json ./packages/config-typescript/package.json
COPY packages/config-eslint/package.json ./packages/config-eslint/package.json
COPY packages/types/package.json ./packages/types/package.json
COPY packages/logger/package.json ./packages/logger/package.json
COPY packages/utils/package.json ./packages/utils/package.json
COPY packages/database/package.json ./packages/database/package.json
COPY apps/web/package.json ./apps/web/package.json

RUN pnpm config set fetch-retries 5 \
 && pnpm config set fetch-retry-factor 2 \
 && pnpm config set fetch-retry-mintimeout 20000 \
 && pnpm config set fetch-retry-maxtimeout 120000 \
 && pnpm config set network-timeout 300000 \
 && pnpm install --frozen-lockfile

COPY tsconfig.base.json ./

COPY packages/config-typescript ./packages/config-typescript
COPY packages/config-eslint ./packages/config-eslint
COPY packages/types ./packages/types
COPY packages/logger ./packages/logger
COPY packages/utils ./packages/utils
COPY packages/database ./packages/database
COPY apps/web ./apps/web

RUN pnpm install --offline --frozen-lockfile

RUN pnpm exec prisma generate --schema=packages/database/prisma/schema.prisma

RUN pnpm --filter @autoops/types build \
 && pnpm --filter @autoops/logger build \
 && pnpm --filter @autoops/utils build \
 && pnpm --filter @autoops/database build \
 && pnpm --filter @autoops/web build

# ─────────────────────────────────────────────────────────────────────────────
# Stage 2: Production Runner
# ─────────────────────────────────────────────────────────────────────────────
FROM node:20-alpine AS runner

RUN apk add --no-cache openssl

WORKDIR /app

RUN addgroup -S autoops \
 && adduser -S autoops -G autoops

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3000
ENV HOSTNAME=0.0.0.0
ENV PATH="/app/node_modules/.bin:/app/apps/web/node_modules/.bin:$PATH"

ARG NEXT_PUBLIC_API_URL=http://localhost:4000
ARG API_INTERNAL_URL=http://api:4000

ENV NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL}
ENV API_INTERNAL_URL=${API_INTERNAL_URL}

COPY --from=builder /repo/package.json ./package.json
COPY --from=builder /repo/pnpm-lock.yaml ./pnpm-lock.yaml
COPY --from=builder /repo/pnpm-workspace.yaml ./pnpm-workspace.yaml

COPY --from=builder /repo/node_modules ./node_modules

COPY --from=builder /repo/packages/types/node_modules ./packages/types/node_modules
COPY --from=builder /repo/packages/logger/node_modules ./packages/logger/node_modules
COPY --from=builder /repo/packages/utils/node_modules ./packages/utils/node_modules
COPY --from=builder /repo/packages/database/node_modules ./packages/database/node_modules
COPY --from=builder /repo/apps/web/node_modules ./apps/web/node_modules

COPY --from=builder /repo/packages/types/package.json ./packages/types/package.json
COPY --from=builder /repo/packages/types/dist ./packages/types/dist

COPY --from=builder /repo/packages/logger/package.json ./packages/logger/package.json
COPY --from=builder /repo/packages/logger/dist ./packages/logger/dist

COPY --from=builder /repo/packages/utils/package.json ./packages/utils/package.json
COPY --from=builder /repo/packages/utils/dist ./packages/utils/dist

COPY --from=builder /repo/packages/database/package.json ./packages/database/package.json
COPY --from=builder /repo/packages/database/dist ./packages/database/dist
COPY --from=builder /repo/packages/database/prisma ./packages/database/prisma

COPY --from=builder /repo/apps/web/package.json ./apps/web/package.json
COPY --from=builder /repo/apps/web/.next ./apps/web/.next

USER autoops

EXPOSE 3000

CMD ["node", "apps/web/node_modules/next/dist/bin/next", "start", "apps/web"]
