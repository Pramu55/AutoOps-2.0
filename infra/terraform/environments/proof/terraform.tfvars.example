# Non-secret example values for local proof validation.
# Copy locally only when needed.
# Real .tfvars files must remain uncommitted.
# Never place credentials, passwords, tokens, or account secrets in tfvars.

project_name        = "autoops"
environment         = "proof"
aws_region          = "ap-south-1"
owner               = "platform-engineering"
cost_center         = "portfolio"
managed_by          = "terraform"
data_classification = "disposable"
